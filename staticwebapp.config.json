{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/css/*", "*.json"]
  },
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["wwrimember"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/index.html",
      "statusCode": 403
    }
  }
}
